SELECT
    org_name,
    parent_org,
    SUM(att_type1) AS total_attendances,
    SUM(over4hr_type1) AS total_breaches,
    ROUND(SUM(over4hr_type1) * 100.0 / NULLIF(SUM(att_type1), 0), 2) AS breach_rate_pct
FROM ae_performance
WHERE att_type1 > 0
GROUP BY org_name, parent_org
ORDER BY breach_rate_pct DESC;